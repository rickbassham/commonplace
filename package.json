{
  "name": "commonplace-mcp",
  "version": "0.2.0",
  "description": "Local-first commonplace book with embedding-backed semantic search via MCP",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "commonplace": "dist/index.js",
    "commonplace-mcp": "dist/bin/commonplace-mcp.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rickbassham/commonplace.git"
  },
  "homepage": "https://github.com/rickbassham/commonplace#readme",
  "bugs": {
    "url": "https://github.com/rickbassham/commonplace/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "embeddings",
    "semantic-search",
    "claude",
    "ai-agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"import('node:fs').then(fs => { fs.chmodSync('dist/bin/commonplace-mcp.js', 0o755); fs.chmodSync('dist/index.js', 0o755); })\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.12.0",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^9.12.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  }
}
